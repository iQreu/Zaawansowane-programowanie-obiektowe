<Window x:Class="BankApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BankApp" Height="640" Width="960"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal">
    <DockPanel>

        <!-- Nagłówek -->
        <Border DockPanel.Dock="Top" Background="{StaticResource NavyBrush}" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" Background="{StaticResource AccentBrush}" CornerRadius="9" Margin="0,0,12,0">
                    <TextBlock Text="B" Foreground="White" FontWeight="Bold" FontSize="19"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BankApp" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="System bankowy — projekt zaawansowanej obiektowości" Foreground="#AEC2E6" FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Pasek statusu -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Zawartość -->
        <TabControl Margin="16,12,16,8">

            <!-- ===== Zakładka: Konta i operacje ===== -->
            <TabItem Header="Konta i operacje">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lista kont -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Twoje konta" Style="{StaticResource SectionTitle}"/>
                            <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Number}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Balance}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Szczegóły + operacje -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Historia transakcji" Style="{StaticResource SectionTitle}"/>

                            <!-- Panel operacji (na dole) -->
                            <Border DockPanel.Dock="Bottom" Background="#F7F9FD" CornerRadius="10" Padding="14" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Wpłata / wypłata -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Kwota" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="Wpłać" Command="{Binding DepositCommand}" Width="100" Margin="0,0,8,0"/>
                                            <Button Content="Wypłać" Command="{Binding WithdrawCommand}" Width="100"
                                                    Style="{StaticResource SecondaryButton}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Przelew -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Numer konta docelowego" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding TargetNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Content="Przelej" Command="{Binding TransferCommand}" Width="100"
                                                HorizontalAlignment="Left" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tabela transakcji (wypełnia środek) -->
                            <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Data" Binding="{Binding Timestamp, StringFormat=g}" Width="150"/>
                                    <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="100"/>
                                    <DataGridTextColumn Header="Kwota" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                                    <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Zakładka: Nowe konto ===== -->
            <TabItem Header="Nowe konto">
                <Grid Margin="0,12,0,0">
                    <Border Style="{StaticResource Card}" Width="420" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Otwórz nowe konto" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Typ konta (lista wykryta automatycznie przez refleksję)"
                                       Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AccountTypes}" SelectedItem="{Binding SelectedType}"
                                      DisplayMemberPath="DisplayName"/>
                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                <TextBlock Text="{Binding SelectedType.Description}" Style="{StaticResource BodyText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                            <Button Content="Otwórz konto" Command="{Binding OpenAccountCommand}"
                                    HorizontalAlignment="Left" Width="140" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Zakładka: Diagnostyka / Raport ===== -->
            <TabItem Header="Diagnostyka / Raport" DataContext="{Binding Diagnostics}">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Wykryte typy kont (refleksja)" Style="{StaticResource SectionTitle}"/>
                            <Button DockPanel.Dock="Bottom" Content="Generuj raport CSV"
                                    Command="{Binding GenerateReportCommand}" Margin="0,12,0,0"/>
                            <ListBox ItemsSource="{Binding DiscoveredTypes}" DisplayMemberPath="DisplayName"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Raport (CSV)" Style="{StaticResource SectionTitle}"/>
                            <Border BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1" CornerRadius="8" Background="#FBFCFE">
                                <TextBox Text="{Binding Report, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                                         BorderThickness="0" Background="Transparent"
                                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
